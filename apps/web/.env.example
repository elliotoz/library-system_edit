# Server-side backend URL for Next.js route handlers
API_URL="http://localhost:3001"

# Browser-visible backend URL for diagnostics and non-proxied client config
NEXT_PUBLIC_API_URL="http://localhost:3001"

# App configuration
NEXT_PUBLIC_APP_NAME="Library System"

# JWT secret — must match apps/api JWT_SECRET for middleware signature verification
# Must be at least 32 characters locally.
JWT_SECRET="change-me-with-at-least-32-characters"

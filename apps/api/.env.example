# Database
DATABASE_URL="postgresql://library_admin:library_password_2024@localhost:5432/library_system?schema=public"

# JWT
JWT_SECRET="change-me-in-production"
JWT_EXPIRATION="7d"

# Server
PORT=3001
NODE_ENV=development

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3001/auth/google/callback"

# CORS
CORS_ORIGIN="http://localhost:3000"

# Uploads (if used)
UPLOAD_DIR="./uploads"

# Ollama (AI)
OLLAMA_BASE_URL="http://localhost:11434"

# Semantic search
AI_SEMANTIC_MODE="hybrid"
AI_EMBEDDINGS_ENABLED="false"

# Cloud Storage (optional — defaults to local disk if not configured)
STORAGE_PROVIDER="local"              # "local" or "s3"
AWS_REGION=""
AWS_S3_BUCKET=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_PUBLIC_BASE_URL=""             # optional — override default S3 URL

# Rate Limiting
THROTTLE_TTL="60"                     # Window in seconds
THROTTLE_LIMIT="20"                   # Max requests per window (global default)
THROTTLE_AUTH_LIMIT="5"               # Max requests for auth endpoints
THROTTLE_AI_LIMIT="15"               # Max requests for AI chat

# Logging
LOG_LEVEL="log"                       # error | warn | log | debug | verbose
ENABLE_REQUEST_LOGGING="true"         # "false" to silence per-request logs

# SMTP Email (optional — falls back to console logging if not configured)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@library.uskudar.edu.tr"

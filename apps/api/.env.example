# Database
DATABASE_URL="postgresql://library_admin:library_password_2024@localhost:5432/library_system?schema=public"

# JWT
JWT_SECRET="change-me-in-production"
JWT_EXPIRATION="7d"

# Server
PORT=3001
NODE_ENV=development

# Google OAuth — leave CLIENT_ID and CLIENT_SECRET empty to disable Google sign-in
# The frontend will hide the "Continue with Google" button if these are not set.
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3001/auth/google/callback"

# CORS — comma-separated list of allowed origins (e.g., "http://localhost:3000,https://app.example.com")
CORS_ORIGIN="http://localhost:3000"

# Frontend URL — canonical URL for password reset links and OAuth redirects
# Falls back to first CORS_ORIGIN if not set. Set this in production.
FRONTEND_URL=""

# Uploads (if used)
UPLOAD_DIR="./uploads"

# Ollama (AI)
OLLAMA_BASE_URL="http://localhost:11434"

# Semantic search
AI_SEMANTIC_MODE="hybrid"
AI_EMBEDDINGS_ENABLED="false"

# Cloud Storage (optional — defaults to local disk if not configured)
STORAGE_PROVIDER="s3"              # "local" or "s3"
AWS_REGION="eu-north-1"
AWS_S3_BUCKET="library-system-upload"
AWS_ACCESS_KEY_ID="AKIA4WHHT42RCVEFMJ4A"
AWS_SECRET_ACCESS_KEY=""
AWS_S3_PUBLIC_BASE_URL=""             # optional — override default S3 URL

# Rate Limiting
THROTTLE_TTL="60"                     # Window in seconds
THROTTLE_LIMIT="20"                   # Max requests per window (global default)
THROTTLE_AUTH_LIMIT="5"               # Max requests for auth endpoints
THROTTLE_AI_LIMIT="15"               # Max requests for AI chat

# Monitoring
MONITOR_OLLAMA="false"                # "true" to include Ollama in /health/ready

# Logging
LOG_LEVEL="log"                       # error | warn | log | debug | verbose
ENABLE_REQUEST_LOGGING="true"         # "false" to silence per-request logs

# SMTP Email — leave SMTP_HOST empty to log emails to console (dev mode)
# In production, configure a real SMTP server for email verification and password reset.
# Example providers: SendGrid, Mailgun, AWS SES, or your institution's SMTP server.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@library.uskudar.edu.tr"
